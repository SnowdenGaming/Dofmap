{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/maps",
      "destination": "/"
    },
    {
      "source": "/community",
      "destination": "/"
    },
    {
      "source": "/login",
      "destination": "/"
    }
  ]
}
